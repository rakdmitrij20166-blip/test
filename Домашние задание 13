import requests
import os

# Установите библиотеку requests: pip install requests

# Замените 'YOUR_API_KEY' на ваш реальный ключ в переменной или 
# установите переменную окружения VT_API_KEY.

# Вставьте SHA-256 хеш файла в переменную resource_hash.

def get_vt_report(resource_hash, api_key):
    url = f"https://www.virustotal.com{resource_hash}"
    
    headers = {
        "accept": "application/json",
        "x-apikey": api_key
    }

    try:
        response = requests.get(url, headers=headers)
        
        # Проверка статуса ответа
        if response.status_code == 200:
            return response.json()
        elif response.status_code == 404:
            return {"error": "Файл не найден в базе VirusTotal."}
        else:
            return {"error": f"Ошибка {response.status_code}: {response.text}"}
            
    except Exception as e:
        return {"error": str(e)}

if __name__ == "__main__":
    # Настройки
    API_KEY = os.getenv("VT_API_KEY", "YOUR_API_KEY") # Ключ из окружения или строка
    # Тестовый хеш (например, хеш файла EICAR для проверки антивирусов)
    FILE_HASH = "91f10b4f8b63f6ae9b0fbeb6ccdbdf28ab648e46508ff9939282a79353899f57"

    print(f"Запрос отчета для: {FILE_HASH}...")
    result = get_vt_report(FILE_HASH, API_KEY)

    # Вывод результатов
    if "data" in result:
        stats = result['data']['attributes']['last_analysis_stats']
        print("\n[СТАТУС СКАННИРОВАНИЯ]")
        print(f"Вредоносных: {stats['malicious']}")
        print(f"Подозрительных: {stats['suspicious']}")
        print(f"Безвредных: {stats['harmless']}")
        print("-" * 30)
        print("Полный JSON ответ:")
        print(result)
    else:
        print(f"Ошибка: {result.get('error')}")